server {
    server_name cuhkstudy.com www.cuhkstudy.com;
    root /var/www/cuhkstudy/public;
    index index.html index.htm;

    # === 简化配置说明 ===
    # 当前使用: cuhkstudy.com (阿里云) + pub-12287e23d91e4005b39b37b16efc1c42.r2.dev (Cloudflare开发链接)
    # CDN子域名 cdn.cuhkstudy.com 已暂时禁用，配置保存在 /etc/nginx/sites-available/cdn-cuhkstudy.disabled
    
    # 启用 gzip 压缩
    gzip on;
    gzip_vary on;
    gzip_min_length 1024;
    gzip_types
        text/plain
        text/css
        text/xml
        text/javascript
        application/javascript
        application/xml+rss
        application/json;

    # 设置R2 CDN变量 (Cloudflare 开发链接)
    set $r2_endpoint "https://pub-12287e23d91e4005b39b37b16efc1c42.r2.dev";

    # PDF 改为 302 跳转至 R2-dev（地址栏直接显示 r2.dev）
    location ~* \.pdf$ {
        add_header Cache-Control "public, max-age=300";
        add_header Access-Control-Allow-Origin "*";
        return 302 $r2_endpoint$uri;
    }
    

    
    # PDF不可用处理
    location @pdf_unavailable {
        return 503 "PDF temporarily unavailable from CDN";
        add_header Content-Type text/plain;
        add_header X-Served-From "cdn-error";
    }
    
    # 图片不可用处理
    location @image_unavailable {
        return 503 "Image temporarily unavailable from CDN";
        add_header Content-Type text/plain;
        add_header X-Served-From "cdn-error";
    }
    
    # 字体不可用处理
    location @font_unavailable {
        return 503 "Font temporarily unavailable from CDN";
        add_header Content-Type text/plain;
        add_header X-Served-From "cdn-error";
    }
    
    # CSS/JS不可用处理
    location @css_js_unavailable {
        return 503 "CSS/JS temporarily unavailable from CDN";
        add_header Content-Type text/plain;
        add_header X-Served-From "cdn-error";
    }
    
    # 图标不可用处理
    location @icon_unavailable {
        return 503 "Icon temporarily unavailable from CDN";
        add_header Content-Type text/plain;
        add_header X-Served-From "cdn-error";
    }

    # 图片 本地直出
    location ~* \.(png|jpg|jpeg)$ {
        try_files $uri =404;
        expires 30d;
        add_header Cache-Control "public, immutable";
    }

    # 字体 本地直出
    location ~* \.(woff|woff2|ttf)$ {
        try_files $uri =404;
        expires 1y;
        add_header Cache-Control "public, immutable";
    }

    # PDF.js已删除，无需特殊配置

    # 直接从R2获取文件
    location @r2_direct {
        # 构建R2 URL - 移除/static前缀
        set $r2_path $uri;
        if ($uri ~ ^/static/(.*)$) {
            set $r2_path /static/$1;
        }
        
        # 代理到R2
        proxy_pass $r2_endpoint$r2_path;
        proxy_set_header Host pub-12287e23d91e4005b39b37b16efc1c42.r2.dev;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        
        # 缓存R2响应
        proxy_cache_valid 200 30d;
        proxy_cache_valid 404 1m;
        
        # 添加标记头
        add_header X-Served-From "r2-cdn";
        add_header Cache-Control "public, immutable";
        
        # 错误处理
        proxy_intercept_errors on;
        error_page 404 = @not_found;
    }

    # 404处理
    location @not_found {
        return 404;
    }

    # 主要位置配置 - HTML/小文件本地优先
    location / {
        # 对于根路径及未知路由，回退到站点首页，避免 404
        try_files $uri $uri/ /index.html;
        
        # 添加安全头
        add_header X-Frame-Options "SAMEORIGIN" always;
        add_header X-XSS-Protection "1; mode=block" always;
        add_header X-Content-Type-Options "nosniff" always;
        add_header Referrer-Policy "no-referrer-when-downgrade" always;
        add_header Strict-Transport-Security "max-age=63072000; includeSubDomains; preload" always;
        add_header Content-Security-Policy "default-src 'self' http: https: data: blob: 'unsafe-inline'; img-src 'self' data: https://447991a9c9d7dad31c67040315d483b2.r2.cloudflarestorage.com; font-src 'self' https://447991a9c9d7dad31c67040315d483b2.r2.cloudflarestorage.com" always;
    }

    # CSS/JS 本地直出
    location ~* \.(css|js)$ {
        try_files $uri =404;
        expires 7d;
        add_header Cache-Control "public";
        access_log off;
    }

    # 小图标和SVG 本地直出
    location ~* \.(svg|ico|gif)$ {
        try_files $uri =404;
        expires 30d;
        add_header Cache-Control "public, immutable";
        access_log off;
    }

    # 静态资源路径（暂不重写至CDN，直接本地）
    # location /static/ {
    #     try_files $uri =404;
    # }

    # API接口测试R2连接
    location /api/r2-status {
        access_log off;
        return 200 '{"status":"ok","endpoint":"$r2_endpoint","optimized":true,"timestamp":"$time_iso8601"}';
        add_header Content-Type application/json;
    }

    # Markdown编辑器代理
    location /editor {
        proxy_pass http://127.0.0.1:8888;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Accept-Encoding "";
        proxy_buffering off;
    }

    # 编辑器API代理
    # Markdown编辑器API代理
    location /api/files {
        proxy_pass http://127.0.0.1:8888;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header Accept-Encoding "";
        proxy_buffering off;
    }
    
    location /api/read/ {
        proxy_pass http://127.0.0.1:8888;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header Accept-Encoding "";
        proxy_buffering off;
    }
    
    location /api/save/ {
        proxy_pass http://127.0.0.1:8888;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header Accept-Encoding "";
        proxy_buffering off;
    }
    


    # 语言重定向配置（已禁用：当前站点未生成 /zh-cn/ 目录）
    # location = / {
    #     set $lang "zh-cn";
    #     if ($http_accept_language ~* "zh-TW|zh-Hant") {
    #         set $lang "zh-tw";
    #     }
    #     return 301 /$lang/;
    # }

    # 禁止访问隐藏文件和备份文件
    location ~ /\.|~$ {
        deny all;
        access_log off;
        log_not_found off;
    }

    # 日志配置
    access_log /var/log/nginx/cuhkstudy_access.log;
    error_log /var/log/nginx/cuhkstudy_error.log;

    listen 443 ssl; # managed by Certbot
    ssl_certificate /etc/letsencrypt/live/cuhkstudy.com/fullchain.pem; # managed by Certbot
    ssl_certificate_key /etc/letsencrypt/live/cuhkstudy.com/privkey.pem; # managed by Certbot
    include /etc/letsencrypt/options-ssl-nginx.conf; # managed by Certbot
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem; # managed by Certbot


}server {
    if ($host = www.cuhkstudy.com) {
        return 301 https://$host$request_uri;
    } # managed by Certbot


    if ($host = cuhkstudy.com) {
        return 301 https://$host$request_uri;
    } # managed by Certbot


    listen 80;
    server_name cuhkstudy.com www.cuhkstudy.com;
    return 404; # managed by Certbot




}